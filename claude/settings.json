{
  "permissions": {
    "allow": [
      "Bash(* --help)",
      "Bash(* --version)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo test *)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh run view *)",
      "Bash(gh search prs *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(grep *)",
      "Bash(hadolint *)",
      "Bash(mise tasks)",
      "Bash(mypy *)",
      "Bash(pre-commit *)",
      "Bash(prek *)",
      "Bash(pytest *)",
      "Bash(rg *)",
      "Bash(ruff *)",
      "Bash(shellcheck *)",
      "Bash(tombi *)",
      "Bash(ty *)",
      "Bash(uv run mypy *)",
      "Bash(uv run pre-commit *)",
      "Bash(uv run prek *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run ty *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "fish ~/.claude/statusline-command.fish"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "editorMode": "vim"
}
