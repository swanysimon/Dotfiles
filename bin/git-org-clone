#!/usr/bin/env fish

for repo in (gh api --paginate "orgs/$argv[1]/repos?sort=pushed&direction=desc&per_page=100&type=source" --jq '.[].full_name')
    set repo_dir $CODEDIR/$repo

    if not test -d $repo_dir
        echo "Cloning $repo"
        gh repo clone $repo $repo_dir -- --quiet
        continue
    end

    echo "Fetching $repo"
    set fetch_output (git -C $repo_dir fetch --all 2>&1)
    set fetch_exit $status

    if test $fetch_exit -ne 0
        echo "Fetch failed: $repo"
        continue
    end

    if not git -C $repo_dir rev-parse --abbrev-ref --symbolic-full-name '@{u}' &>/dev/null
        if test -z "$fetch_output"
            echo "No updates to $repo, stopping"
            break
        end
        echo "No upstream found for $repo"
        continue
    end

    set head_before (git -C $repo_dir rev-parse HEAD)
    if not git -C $repo_dir rebase --quiet
        git -C $repo_dir rebase --abort 2>/dev/null
        echo "Rebase failed for $repo"
        continue
    end
    set head_after (git -C $repo_dir rev-parse HEAD)

    if test -z "$fetch_output" && test "$head_before" = "$head_after"
        echo "No updates to $repo, stopping"
        break
    end
end
